{
  "info": {
    "name": "Malenia API",
    "description": "Маркетинговый дашборд Malenia — полная коллекция API эндпоинтов.\n\nБазовый URL: {{base_url}}\n\nАутентификация: Bearer токен в переменной {{access_token}}.\nПолучить токен: POST /api/auth/login → скопировать accessToken → вставить в переменную коллекции.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4000/api", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "project_slug", "value": "parent-club", "type": "string" },
    { "key": "project_platform_id", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "description": "Аутентификация и управление сессией",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('access_token', json.accessToken);",
                  "  console.log('Token saved:', json.accessToken.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@a-school.kz\",\n  \"password\": \"changeme123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "description": "Вход по email + пароль. Токен автоматически сохраняется в переменную {{access_token}}."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{base_url}}/auth/refresh", "host": ["{{base_url}}"], "path": ["auth", "refresh"] },
            "description": "Обновить access токен через refresh токен (из cookie)."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"] },
            "description": "Завершить сессию, очистить refresh токен."
          }
        }
      ]
    },
    {
      "name": "👤 Users",
      "description": "Управление пользователями и профилем",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/users/me", "host": ["{{base_url}}"], "path": ["users", "me"] },
            "description": "Профиль текущего авторизованного пользователя."
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Новое имя\"\n}"
            },
            "url": { "raw": "{{base_url}}/users/me", "host": ["{{base_url}}"], "path": ["users", "me"] }
          }
        },
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/users", "host": ["{{base_url}}"], "path": ["users"] },
            "description": "Только ADMIN. Список всех пользователей."
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"name\": \"Имя\",\n  \"password\": \"password123\",\n  \"role\": \"ANALYST\"\n}"
            },
            "url": { "raw": "{{base_url}}/users", "host": ["{{base_url}}"], "path": ["users"] },
            "description": "Только ADMIN. Роли: ADMIN, MARKETING_DIRECTOR, SMM_MANAGER, ANALYST, CONTENT_MANAGER, VIEWER."
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"SMM_MANAGER\",\n  \"isActive\": true\n}"
            },
            "url": { "raw": "{{base_url}}/users/:id", "host": ["{{base_url}}"], "path": ["users", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Только ADMIN."
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/users/:id", "host": ["{{base_url}}"], "path": ["users", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Только ADMIN."
          }
        }
      ]
    },
    {
      "name": "📁 Projects",
      "description": "Проекты и их метрики",
      "item": [
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/projects", "host": ["{{base_url}}"], "path": ["projects"] },
            "description": "Все 6 проектов с их платформами и статусами подключений."
          }
        },
        {
          "name": "Get Project",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/projects/{{project_slug}}",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_slug}}"]
            },
            "description": "Слаги: parent-club, a-school, millimone, ayaru-show, teachers, miss-mari"
          }
        },
        {
          "name": "Get Project Metrics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/projects/{{project_slug}}/metrics?period=30d",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_slug}}", "metrics"],
              "query": [
                { "key": "period", "value": "30d", "description": "7d, 14d, 30d, 90d" },
