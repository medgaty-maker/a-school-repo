              "raw": "{{base_url}}/integrations/youtube/top-videos?limit=10&sort=desc",
              "host": ["{{base_url}}"],
              "path": ["integrations", "youtube", "top-videos"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "desc", "description": "desc = топ, asc = антирейтинг" }
