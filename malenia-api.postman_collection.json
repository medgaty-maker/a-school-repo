              ]
            },
            "description": "Снапшоты метрик проекта по всем подключённым платформам."
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Новое название\"\n}"
            },
            "url": { "raw": "{{base_url}}/projects/:id", "host": ["{{base_url}}"], "path": ["projects", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "ADMIN или MARKETING_DIRECTOR."
          }
        }
      ]
    },
    {
