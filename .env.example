# --- Database (docker-compose) ---
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=dashboard
POSTGRES_DB=dashboard
DATABASE_URL=postgresql://dashboard:dashboard@localhost:5432/dashboard?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Backend ---
BACKEND_PORT=4000
JWT_SECRET=replace-me-with-strong-random-string
JWT_REFRESH_SECRET=replace-me-with-another-strong-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
ENCRYPTION_KEY=32-byte-hex-string-for-token-encryption-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# --- Admin seed ---
ADMIN_EMAIL=admin@a-school.kz
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Amir Abdullaev

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- YouTube (OAuth 2.0) ---
# https://console.cloud.google.com/ — создать OAuth client (Web application)
# Authorized redirect URI: http://localhost:4000/integrations/youtube/oauth/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_OAUTH_REDIRECT=http://localhost:4000/integrations/youtube/oauth/callback

# --- Meta Graph (Instagram + Facebook + Ads) ---
# https://developers.facebook.com/apps — создать приложение Business type
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT=http://localhost:4000/integrations/meta/oauth/callback
